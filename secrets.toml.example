# Copia questo file in .streamlit/secrets.toml in locale.
# Su Streamlit Cloud inserisci questi valori nella sezione App > Settings > Secrets.

FP_IMAP_HOST = "imap.gmail.com"
FP_IMAP_PORT = "993"
FP_IMAP_USER = "nome@email.it"
FP_IMAP_PASSWORD = "app_password"
FP_IMAP_FOLDER = "INBOX"

# In alternativa puoi usare anche la sezione [imap]:
# [imap]
# host = "imap.gmail.com"
# port = "993"
# user = "nome@email.it"
# password = "app_password"
# folder = "INBOX"
